FLASK_DEBUG=true
PORT=5000
DATABASE_NAME=hackathon_db
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres

# --- Alerting (email) --------------------------------------------------------
# Gmail: create an App Password at https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-sender@gmail.com
SMTP_PASSWORD=your-app-password
ALERT_EMAIL_FROM=your-sender@gmail.com
ALERT_EMAIL_TO=oncall-engineer@example.com

# --- Alert tuning (optional) -------------------------------------------------
# How often the background thread checks conditions (seconds)
ALERT_CHECK_INTERVAL=30
# Min time between repeat alerts for the same condition (seconds)
ALERT_COOLDOWN_SECONDS=300
# 5xx rate that triggers the high-error-rate alert (0.0–1.0)
ALERT_ERROR_RATE_THRESHOLD=0.10
# Min requests in the 2-min window before error-rate alert can fire
ALERT_MIN_REQUESTS=5
